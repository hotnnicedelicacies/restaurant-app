# =====================================================================
# Hot N Nice Delicacies · Environment configuration
# =====================================================================
# Copy this file to `.env.local` and fill in the values. Never commit
# `.env.local`. The keys are grouped by phase in the rebuild plan.
# =====================================================================

# --- Public site URL (Phase 0) ---
# Used for canonical URLs, OG images, sitemap, Stripe webhooks etc.
# In dev: http://localhost:3000   /   In prod: https://hotnnicedelicacies.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase (Phase 2) ---
# Create a project at https://supabase.com, then:
#   - Run `supabase/migrations/*.sql` against your project (in order).
#   - Find your URL + keys in Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Secret key — KEEP SECRET. Only used server-side for privileged
# operations (Stripe webhook handlers, seeding, etc.). Never expose
# to the browser.
SUPABASE_SECRET_KEY=

# --- Stripe (Phase 4) ---
# Create a Stripe account at https://stripe.com (test mode for dev).
# Publishable + secret keys: Developers → API keys.
# Webhook secret: Developers → Webhooks → "Add endpoint":
#   URL:    https://<your-domain>/api/stripe/webhook
#   (Local: stripe listen --forward-to localhost:3000/api/stripe/webhook)
#   Events to send (4):
#     - payment_intent.succeeded       (mark order paid, email customer)
#     - payment_intent.payment_failed  (mark order failed)
#     - charge.refunded                (sync refund amount back to our DB)
#     - charge.dispute.created         (alert admin)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Resend (Phase 5) ---
# Transactional email for order confirmations, status updates, receipts.
# Get an API key at https://resend.com/api-keys. The sender domain must be
# verified at Resend (Domains tab) with SPF, DKIM, DMARC.
RESEND_API_KEY=
ORDER_FROM_EMAIL="Hot N Nice Delicacies <orders@hotnnicedelicacies.com>"
ORDER_NOTIFICATION_EMAIL=hotnnicedelicacies@gmail.com

# --- Optional: rate-limit / observability (later) ---
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
